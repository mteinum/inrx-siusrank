<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1180"
        d:DesignHeight="820"
        x:Class="InrxToSiusRank.Desktop.MainWindow"
        Title="InrxToSiusRank"
        MinWidth="980"
        MinHeight="720"
        Width="1180"
        Height="820">
  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem x:Name="CreateEventMenuItem" Header="_Create event.json" />
        <MenuItem x:Name="OpenEventMenuItem" Header="_Open event.json" />
        <MenuItem x:Name="SaveEventMenuItem" Header="_Save event.json" />
      </MenuItem>
    </Menu>

    <Border DockPanel.Dock="Top"
            Background="#f6f8fa"
            BorderBrush="#d0d7de"
            BorderThickness="0,0,0,1"
            Padding="16,12">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
        <TextBlock Text="InrxToSiusRank"
                   FontSize="20"
                   FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Text="Lokal testklient"
                   Foreground="#57606a"
                   Margin="0,4,0,0" />
        <TextBlock x:Name="StatusText"
                   Grid.Column="1"
                   Grid.RowSpan="2"
                   VerticalAlignment="Center"
                   Foreground="#57606a"
                   Text="Klar" />
      </Grid>
    </Border>

    <Grid RowDefinitions="Auto,*" Margin="16" RowSpacing="12">
      <TabControl Grid.Row="0">
        <TabItem Header="Event">
          <Border Margin="0,12,0,0" BorderBrush="#d0d7de" BorderThickness="0,0,0,1" Padding="0,0,0,12">
            <Grid ColumnDefinitions="130,*,Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
              <TextBlock Text="event.json" VerticalAlignment="Center" />
              <TextBox x:Name="EventFilePathBox" Grid.Column="1" Grid.ColumnSpan="3" IsReadOnly="True" PlaceholderText="No event file loaded" />

              <TextBlock Grid.Row="1" Text="storage.db3" VerticalAlignment="Center" />
              <TextBox x:Name="DatabasePathBox" Grid.Row="1" Grid.Column="1" PlaceholderText="Path to storage.db3" />
              <Button x:Name="BrowseDatabaseButton" Grid.Row="1" Grid.Column="2" Content="Velg fil" />
              <Button x:Name="LoadDatabaseButton" Grid.Row="1" Grid.Column="3" Content="Kontroller" />

              <TextBlock Grid.Row="2" Text="Stevnesøk" VerticalAlignment="Center" />
              <TextBox x:Name="StevneSearchBox" Grid.Row="2" Grid.Column="1" PlaceholderText="Navn eller dato, tom = siste 100" />
              <Button x:Name="SearchStevnerButton" Grid.Row="2" Grid.Column="2" Content="Søk" />
              <Button x:Name="RefreshEventClassesButton" Grid.Row="2" Grid.Column="3" Content="Oppdater klasser" />

              <TextBlock Grid.Row="3" Text="Stevner" VerticalAlignment="Top" Margin="0,4,0,0" />
              <ScrollViewer Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" MaxHeight="180" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="StevneListPanel" Spacing="4" />
              </ScrollViewer>

              <TextBlock Grid.Row="4" Text="Valgte ids" VerticalAlignment="Center" />
              <TextBox x:Name="StevneIdsBox" Grid.Row="4" Grid.Column="1" PlaceholderText="413-417 or 413,414" />
              <TextBlock Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Foreground="#57606a" Text="Eksport/writeback" />

              <TextBlock Grid.Row="5" Text="Stevnetype" VerticalAlignment="Top" Margin="0,4,0,0" />
              <ScrollViewer Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" MaxHeight="140" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="EventTypesPanel" Spacing="4" />
              </ScrollViewer>

              <TextBlock Grid.Row="6" Text="Encoding" VerticalAlignment="Center" />
              <ComboBox x:Name="EncodingBox" Grid.Row="6" Grid.Column="1" Width="180" HorizontalAlignment="Left" SelectedIndex="0">
                <ComboBoxItem Content="utf8-bom" />
                <ComboBoxItem Content="windows-1252" />
              </ComboBox>
            </Grid>
          </Border>
        </TabItem>

        <TabItem Header="CSV export">
          <Grid Margin="0,12,0,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnDefinitions="150,*,Auto" RowSpacing="10" ColumnSpacing="8">
            <TextBlock Text="SIUS Rank folder" VerticalAlignment="Center" />
            <TextBox x:Name="SiusRankFolderBox" Grid.Column="1" PlaceholderText="C:\SIUS\SiusRank" />
            <Button x:Name="BrowseSiusRankFolderButton" Grid.Column="2" Content="Velg mappe" />

            <TextBlock Grid.Row="1" Text="Output directory" VerticalAlignment="Center" />
            <TextBox x:Name="OutputDirectoryBox" Grid.Row="1" Grid.Column="1" PlaceholderText="siusrank-import directory" />
            <Button x:Name="BrowseOutputButton" Grid.Row="1" Grid.Column="2" Content="Velg mappe" />

            <TextBlock Grid.Row="2" Text="Shooter groups XML" VerticalAlignment="Center" />
            <TextBox x:Name="ShooterGroupsTemplateBox" Grid.Row="2" Grid.Column="1" PlaceholderText="Optional ShooterGroupsTemplate.xml" />
            <Button x:Name="BrowseShooterGroupsButton" Grid.Row="2" Grid.Column="2" Content="Velg fil" />

            <TextBlock Grid.Row="3" Text="SIUS templates" VerticalAlignment="Center" />
            <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
              <Button x:Name="CopyTemplatesButton" Content="Kopier templates til SIUS Rank" />
              <TextBlock VerticalAlignment="Center" Foreground="#57606a" Text="C:\SIUS\SiusRank\Resources\Templates" />
            </StackPanel>

            <TextBlock Grid.Row="4" Text="Øvelse" VerticalAlignment="Center" />
            <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
              <ComboBox x:Name="OvelseSelectBox" Width="320" />
              <Button x:Name="RefreshOvelserButton" Content="Oppdater øvelser" />
              <TextBox x:Name="OvelseFilterBox" IsVisible="False" />
            </StackPanel>

            <TextBlock Grid.Row="5" Text="Silhuett" VerticalAlignment="Center" />
            <ComboBox x:Name="SilhouetteShootersPerStandBox" Grid.Row="5" Grid.Column="1" Width="180" HorizontalAlignment="Left" SelectedIndex="1">
              <ComboBoxItem Content="1 skytter per stativ" />
              <ComboBoxItem Content="2 skyttere per stativ" />
            </ComboBox>

            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <Button x:Name="CreateBibMapButton" Content="Opprett/oppdater bib-map.csv" />
              <Button x:Name="RunExportButton" Content="Lag CSV-filer" />
            </StackPanel>
          </Grid>
        </TabItem>

        <TabItem Header="SIUS Rank writeback">
          <Grid Margin="0,12,0,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" ColumnDefinitions="150,*,Auto" RowSpacing="10" ColumnSpacing="8">
            <TextBlock Text="Exports directory" VerticalAlignment="Center" />
            <TextBox x:Name="ExportsDirectoryBox" Grid.Column="1" PlaceholderText="SIUS Rank Exports directory" />
            <Button x:Name="BrowseExportsButton" Grid.Column="2" Content="Velg mappe" />

            <TextBlock Grid.Row="1" Text="bib-map.csv" VerticalAlignment="Center" />
            <TextBox x:Name="BibMapPathBox" Grid.Row="1" Grid.Column="1" PlaceholderText="Optional, auto-detected if empty" />
            <Button x:Name="BrowseBibMapButton" Grid.Row="1" Grid.Column="2" Content="Velg fil" />

            <TextBlock Grid.Row="2" Text="Event filter" VerticalAlignment="Center" />
            <TextBox x:Name="EventFilterBox" Grid.Row="2" Grid.Column="1" PlaceholderText="Optional: HurtigFin_M,HurtigGrov_Apen" />

            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <Button x:Name="RunWritebackPreviewButton" Content="Tørrkjør writeback" />
              <Button x:Name="RunWritebackApplyButton" Content="Skriv til inrX" />
            </StackPanel>

            <TextBlock Grid.Row="4" Text="Øvelse/klasse" VerticalAlignment="Top" Margin="0,4,0,0" />
            <ScrollViewer Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" MaxHeight="220" VerticalScrollBarVisibility="Auto">
              <StackPanel x:Name="WritebackClassRowsPanel" Spacing="6" />
            </ScrollViewer>
          </Grid>
        </TabItem>

        <TabItem Header="SSC">
          <Grid Margin="0,12,0,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnDefinitions="150,*,Auto" RowSpacing="10" ColumnSpacing="8">
            <TextBlock Text="Organization name" VerticalAlignment="Center" />
            <TextBox x:Name="SscOrganizationNameBox" Grid.Column="1" PlaceholderText="Legacy" />

            <TextBlock Grid.Row="1" Text="Organization id" VerticalAlignment="Center" />
            <TextBox x:Name="SscOrganizationIdBox" Grid.Row="1" Grid.Column="1" PlaceholderText="f95a2bc3-79bd-4c24-98b6-4e17f99bbfaf" />

            <TextBlock Grid.Row="2" Text="bib-map.csv" VerticalAlignment="Center" />
            <TextBox x:Name="SscBibMapPathBox" Grid.Row="2" Grid.Column="1" PlaceholderText="siusrank-import/bib-map.csv" />
            <Button x:Name="BrowseSscBibMapButton" Grid.Row="2" Grid.Column="2" Content="Velg fil" />

            <TextBlock Grid.Row="3" Text="Output directory" VerticalAlignment="Center" />
            <TextBox x:Name="SscOutputDirectoryBox" Grid.Row="3" Grid.Column="1" PlaceholderText="ssc setup output directory" />
            <Button x:Name="BrowseSscOutputButton" Grid.Row="3" Grid.Column="2" Content="Velg mappe" />

            <TextBlock Grid.Row="4" Text="Users CSV" VerticalAlignment="Center" />
            <TextBox x:Name="SscUsersCsvPathBox" Grid.Row="4" Grid.Column="1" PlaceholderText="ssc-users.csv for validation" />
            <Button x:Name="BrowseSscUsersCsvButton" Grid.Row="4" Grid.Column="2" Content="Velg fil" />

            <TextBlock Grid.Row="5" Text="Startlag" VerticalAlignment="Center" />
            <TextBox x:Name="SscStartlagBox" Grid.Row="5" Grid.Column="1" PlaceholderText="2026-07-06T09:00:00" />

            <TextBlock Grid.Row="6" Text="Lane count" VerticalAlignment="Center" />
            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <ComboBox x:Name="SscLaneCountBox" Width="90" SelectedIndex="2">
                <ComboBoxItem Content="10" />
                <ComboBoxItem Content="25" />
                <ComboBoxItem Content="40" />
              </ComboBox>
              <Button x:Name="RunSscUsersButton" Content="Export SSC Users" />
              <Button x:Name="RunSscValidateButton" Content="Validate SSC" />
              <Button x:Name="RunSscLanesButton" Content="Export SSC Lanes/Reset" />
            </StackPanel>
          </Grid>
        </TabItem>

        <TabItem Header="Diagnostics">
          <Grid Margin="0,12,0,0" RowDefinitions="Auto,*" RowSpacing="10">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button x:Name="ShowStevnerButton" Content="Vis siste stevner" />
              <Button x:Name="ShowSelectedOvelserButton" Content="Vis valgte øvelser" />
            </StackPanel>
          </Grid>
        </TabItem>
      </TabControl>

      <Grid Grid.Row="1" RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
          <TextBlock Text="Log" FontWeight="SemiBold" />
          <Button x:Name="ClearLogButton" Grid.Column="1" Content="Tøm" />
        </Grid>
        <TextBox x:Name="LogBox"
                 Grid.Row="1"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas, Menlo, Cascadia Mono, monospace"
                 FontSize="12" />
      </Grid>
    </Grid>
  </DockPanel>
</Window>
