<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1180"
        d:DesignHeight="820"
        x:Class="InrxToSiusRank.Desktop.MainWindow"
        Title="InrxToSiusRank"
        MinWidth="980"
        MinHeight="720"
        Width="1180"
        Height="820">
  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_Fil">
        <MenuItem x:Name="CreateEventMenuItem" Header="_Opprett event.json" />
        <MenuItem x:Name="OpenEventMenuItem" Header="_Åpne event.json" />
        <MenuItem x:Name="SaveEventMenuItem" Header="_Lagre event.json" />
        <MenuItem x:Name="CloseEventMenuItem" Header="_Lukk stevne" />
        <Separator />
        <MenuItem x:Name="SettingsMenuItem" Header="_Innstillinger..." />
      </MenuItem>
    </Menu>

    <Border DockPanel.Dock="Top"
            Background="#f6f8fa"
            BorderBrush="#d0d7de"
            BorderThickness="0,0,0,1"
            Padding="16,10">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
        <TextBlock Text="InrxToSiusRank" FontSize="20" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Text="Lokal testklient for SIUS Rank, inrX og SSC"
                   Classes="muted"
                   Margin="0,2,0,0" />
        <Border x:Name="StatusBadge"
                Grid.Column="1"
                Grid.RowSpan="2"
                Classes="status-badge">
          <TextBlock x:Name="StatusText" FontWeight="SemiBold" Text="Klar" />
        </Border>
      </Grid>
    </Border>

    <Grid Margin="14">
      <TabControl>
        <TabItem Header="Event">
          <Grid RowDefinitions="Auto,*" Margin="0,10,0,0" RowSpacing="8">
            <Border Classes="section-card">
              <StackPanel Spacing="8">
                <TextBlock Text="Oppsett" Classes="section-title" />
                <Grid ColumnDefinitions="110,*,Auto,Auto,Auto,110,220"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="6">
                  <TextBlock Text="event.json" Classes="form-label" />
                  <TextBox x:Name="EventFilePathBox"
                           Grid.Column="1"
                           Grid.ColumnSpan="3"
                           IsReadOnly="True"
                           PlaceholderText="Ingen event-fil lastet" />
                  <Button x:Name="CreateEventButton" Grid.Column="4" Classes="primary" Content="Opprett" />
                  <Button x:Name="OpenEventButton" Grid.Column="5" Content="Åpne" />
                  <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                    <Button x:Name="SaveEventButton" Content="Lagre" />
                    <Button x:Name="CloseEventButton" Content="Lukk" />
                  </StackPanel>

                  <TextBlock Grid.Row="1" Text="storage.db3" Classes="form-label" />
                  <TextBox x:Name="DatabasePathBox"
                           Grid.Row="1"
                           Grid.Column="1"
                           Grid.ColumnSpan="3"
                           PlaceholderText="Sti til storage.db3" />
                  <Button x:Name="BrowseDatabaseButton" Grid.Row="1" Grid.Column="4" Content="Velg fil" />
                  <Button x:Name="LoadDatabaseButton" Grid.Row="1" Grid.Column="5" Content="Kontroller" />

                  <ComboBox x:Name="EncodingBox"
                            IsVisible="False"
                            SelectedIndex="0">
                    <ComboBoxItem Content="utf8-bom" />
                    <ComboBoxItem Content="windows-1252" />
                  </ComboBox>

                  <TextBlock Grid.Row="2" Text="Valgte ids" Classes="form-label" />
                  <TextBox x:Name="StevneIdsBox"
                           Grid.Row="2"
                           Grid.Column="1"
                           PlaceholderText="413-417 eller 413,414" />
                  <TextBlock x:Name="EventActionHelpText"
                             Grid.Row="2"
                             Grid.Column="2"
                             Grid.ColumnSpan="5"
                             Classes="warning-helper"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Row="3"
                             Grid.Column="1"
                             Grid.ColumnSpan="6"
                             Text="Stier under stevnemappen vises relativt til event.json."
                             Classes="helper" />
                </Grid>
              </StackPanel>
            </Border>

            <Grid Grid.Row="1">
              <Border Classes="section-card">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="6">
                  <Grid ColumnDefinitions="110,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                    <TextBlock Text="Stevnesøk" Classes="form-label" />
                    <TextBox x:Name="StevneSearchBox"
                             Grid.Column="1"
                             PlaceholderText="Navn eller dato, tom = siste 100" />
                    <Button x:Name="SearchStevnerButton" Grid.Column="2" Content="Søk" />
                    <Button x:Name="RefreshEventClassesButton" Grid.Column="3" Content="Oppdater klasser" />
                    <Button x:Name="SelectAllStevnerButton" Grid.Column="4" Content="Velg alle" />
                    <Button x:Name="ClearStevnerButton" Grid.Column="5" Content="Fjern valg" />
                  </Grid>

                  <TextBlock x:Name="StevneResultCountText"
                             Grid.Row="1"
                             Classes="helper"
                             Text="Ingen søk kjørt." />

                  <Border Grid.Row="2"
                          Background="#f6f8fa"
                          BorderBrush="#d0d7de"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="8,5">
                    <Grid ColumnDefinitions="32,92,60,2*,130,2*" ColumnSpacing="8">
                      <TextBlock Grid.Column="1" Text="Dato" Classes="muted" FontWeight="SemiBold" />
                      <TextBlock Grid.Column="2" Text="Id" Classes="muted" FontWeight="SemiBold" />
                      <TextBlock Grid.Column="3" Text="Navn" Classes="muted" FontWeight="SemiBold" />
                      <TextBlock Grid.Column="4" Text="Type" Classes="muted" FontWeight="SemiBold" />
                      <TextBlock Grid.Column="5" Text="Øvelser" Classes="muted" FontWeight="SemiBold" />
                    </Grid>
                  </Border>

                  <ScrollViewer Grid.Row="3"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Auto">
                    <StackPanel x:Name="StevneListPanel" Spacing="2" />
                  </ScrollViewer>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </TabItem>

        <TabItem Header="CSV export">
          <Grid RowDefinitions="Auto,*" Margin="0,10,0,0" RowSpacing="8">
            <Border Classes="section-card">
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="6">
                <TextBlock Text="CSV-oppsett" Classes="section-title" />

                <Grid Grid.Row="1" ColumnDefinitions="170,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                  <TextBlock Text="SIUS Rank-mappe" Classes="form-label" />
                  <TextBox x:Name="SiusRankFolderBox" Grid.Column="1" PlaceholderText="C:\SIUS\SiusRank" />
                  <Button x:Name="BrowseSiusRankFolderButton" Grid.Column="2" Content="Velg mappe" />

                  <TextBlock Grid.Row="1" Text="Output-mappe" Classes="form-label" />
                  <TextBox x:Name="OutputDirectoryBox" Grid.Row="1" Grid.Column="1" PlaceholderText="siusrank-import mappe" />
                  <Button x:Name="BrowseOutputButton" Grid.Row="1" Grid.Column="2" Content="Velg mappe" />

                  <TextBlock Grid.Row="2" Text="ShooterGroupsTemplate.xml" Classes="form-label" />
                  <TextBox x:Name="ShooterGroupsTemplateBox" Grid.Row="2" Grid.Column="1" PlaceholderText="Valgfri ShooterGroupsTemplate.xml" />
                  <Button x:Name="BrowseShooterGroupsButton" Grid.Row="2" Grid.Column="2" Content="Velg fil" />
                </Grid>
                <TextBlock Grid.Row="2"
                           Grid.ColumnSpan="2"
                           Text="Stier under stevnemappen vises relativt til event.json."
                           Classes="helper" />

                <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="120,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                  <TextBlock Text="Øvelse" Classes="form-label" />
                  <ComboBox x:Name="OvelseSelectBox" Grid.Column="1" MinWidth="260" />
                  <Button x:Name="RefreshOvelserButton" Grid.Column="2" Content="Oppdater øvelser" />
                  <TextBox x:Name="OvelseFilterBox" IsVisible="False" />

                  <TextBlock Grid.Row="1" Text="Silhuett" Classes="form-label" />
                  <ComboBox x:Name="SilhouetteShootersPerStandBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            Width="200"
                            HorizontalAlignment="Left"
                            SelectedIndex="1">
                    <ComboBoxItem Content="1 skytter per stativ" />
                    <ComboBoxItem Content="2 skyttere per stativ" />
                  </ComboBox>

                  <Button x:Name="CopyTemplatesButton"
                          Grid.Row="1"
                          Grid.Column="2"
                          Content="Kopier templates" />

                  <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="CreateBibMapButton" Content="Opprett/oppdater bib-map.csv" />
                    <Button x:Name="RunExportButton" Classes="primary" Content="Lag CSV-filer" />
                    <Button x:Name="RunSiusDataStartListExportButton" Content="Lag CSV fra SIUS Data" />
                  </StackPanel>
                </Grid>

                <TextBlock x:Name="CsvActionHelpText"
                           Grid.Row="3"
                           Grid.ColumnSpan="2"
                           Classes="warning-helper" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="section-card">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="6">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBlock Text="CSV preflight" Classes="section-title" />
                  <TextBlock x:Name="CsvPreflightSummaryText" Grid.Column="1" Classes="helper" VerticalAlignment="Center" />
                </Grid>

                <Border Grid.Row="1"
                        Background="#f6f8fa"
                        BorderBrush="#d0d7de"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,5">
                  <Grid ColumnDefinitions="70,92,72,1.5*,100,1.2*,90,70,1.6*" ColumnSpacing="8">
                    <TextBlock Text="Include" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="Dato" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2" Text="Stevne.Id" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="3" Text="Stevne" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="4" Text="Stevnetype" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="5" Text="Øvelse" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="6" Text="OvelseDef.Id" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="7" Text="Startere" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="8" Text="Status" Classes="muted" FontWeight="SemiBold" />
                  </Grid>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                  <StackPanel x:Name="CsvPreflightRowsPanel" Spacing="2" />
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="SIUS Rank writeback">
          <Grid RowDefinitions="Auto,Auto,*" Margin="0,10,0,0" RowSpacing="8">
            <Border Classes="section-card">
              <Grid ColumnDefinitions="170,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                <TextBlock Text="SIUS Rank-resultater" Grid.ColumnSpan="3" Classes="section-title" />
                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="3"
                           Text="Trykk Rank List Main i SIUS Rank. Deretter trykker du Finn resultater. Programmet søker i stevnemappen og finner Exports-mappene automatisk."
                           Classes="helper" />

                <TextBlock Grid.Row="2" Text="bib-map.csv" Classes="form-label" />
                <TextBox x:Name="BibMapPathBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         IsReadOnly="True"
                         PlaceholderText="Avledes fra CSV output" />

                <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="8">
                  <Button x:Name="ScanWritebackResultsButton" Classes="primary" Content="Finn resultater i stevnemappen" />
                  <Button x:Name="OpenEventFromWritebackButton" Content="Åpne event.json" />
                  <TextBlock x:Name="WritebackActionHelpText" Classes="warning-helper" VerticalAlignment="Center" />
                </StackPanel>

                <Expander Grid.Row="4" Grid.ColumnSpan="3" Header="Avansert: manuell import fra valgt Exports-mappe" IsExpanded="False">
                  <Grid ColumnDefinitions="160,*,Auto,160,1.2*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8" Margin="0,8,0,0">
                    <TextBlock Grid.ColumnSpan="5" Text="Brukes bare hvis automatisk søk ikke finner resultatene." Classes="helper" />
                    <TextBlock Grid.Row="1" Text="Eksportmappe" Classes="form-label" />
                    <TextBox x:Name="ExportsDirectoryBox" Grid.Row="1" Grid.Column="1" PlaceholderText="SIUS Rank Exports mappe" />
                    <Button x:Name="BrowseExportsButton" Grid.Row="1" Grid.Column="2" Content="Velg mappe" />

                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Eventfilter" Classes="form-label" />
                    <TextBox x:Name="EventFilterBox" Grid.Row="1" Grid.Column="4" PlaceholderText="Valgfritt: HurtigFin_M,HurtigGrov_Apen" />

                    <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="8">
                      <Button x:Name="RunWritebackPreviewButton" Content="Tørrkjør manuell" />
                      <Button x:Name="RunWritebackApplyButton" Classes="danger" Content="Skriv manuell til inrX" />
                      <TextBlock Text="Brukes bare for engangsimport fra en vilkårlig Exports-mappe." Classes="helper" VerticalAlignment="Center" />
                    </StackPanel>
                  </Grid>
                </Expander>
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="section-card">
              <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8">
                <Button x:Name="ValidateAllWritebackButton" Content="Valider alle" />
                <Button x:Name="DryRunReadyWritebackButton" Grid.Column="1" Content="Tørrkjør alle klare" />
                <Button x:Name="ApplyValidatedWritebackButton" Grid.Column="2" Classes="danger" Content="Skriv validerte til inrX" />
                <TextBlock x:Name="WritebackScanSummaryText" Grid.Column="3" Classes="helper" VerticalAlignment="Center" />
              </Grid>
            </Border>

            <Border Grid.Row="2" Classes="section-card">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="6">
                <TextBlock Text="Resultater per klasse" Classes="section-title" />
                <Grid Grid.Row="1" ColumnDefinitions="70,150,1.6*,80,220" ColumnSpacing="8">
                  <TextBlock Text="Klasse" Classes="muted" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1" Text="Status" Classes="muted" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="2" Text="Resultatmappe" Classes="muted" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="3" Text="Filer" Classes="muted" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="4" Text="Handlinger" Classes="muted" FontWeight="SemiBold" />
                </Grid>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                  <StackPanel x:Name="WritebackClassRowsPanel" Spacing="2" />
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="SSC">
          <Grid RowDefinitions="Auto,Auto,*" Margin="0,10,0,0" RowSpacing="8">
            <Border Classes="section-card">
              <Grid ColumnDefinitions="1.1*,1.2*" ColumnSpacing="18" RowDefinitions="Auto,Auto">
                <StackPanel>
                  <TextBlock Text="Stevne og startlag" Classes="section-title" />
                  <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                    <TextBlock Text="Stevne" Classes="form-label" />
                    <ComboBox x:Name="SscStevneBox"
                              Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Velg stevne" />
                    <TextBlock Grid.Row="1" Text="Startlag" Classes="form-label" />
                    <ComboBox x:Name="SscStartlagComboBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Velg startlag" />
                    <TextBlock Grid.Row="2" Text="Antall baner" Classes="form-label" />
                    <ComboBox x:Name="SscLaneCountBox" Grid.Row="2" Grid.Column="1" Width="90" HorizontalAlignment="Left" SelectedIndex="2">
                      <ComboBoxItem Content="10" />
                      <ComboBoxItem Content="25" />
                      <ComboBoxItem Content="40" />
                    </ComboBox>
                  </Grid>
                  <TextBlock x:Name="SscStevneDetailsText" Margin="118,6,0,0" Classes="helper" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                  <TextBlock Text="Arbeidsområde" Classes="section-title" />
                  <TextBlock x:Name="SscOrganizationSummaryText" Classes="helper" />
                  <TextBlock x:Name="SscOutputSummaryText" Classes="helper" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="RunSscNextStepButton" Classes="primary" Content="Neste steg" />
                    <Button x:Name="OpenSscOutputButton" Content="Åpne mappe" />
                  </StackPanel>
                </StackPanel>

                <Expander Grid.Row="1" Grid.ColumnSpan="2" Header="Avansert: filer og organisasjon" Margin="0,10,0,0">
                  <Grid ColumnDefinitions="160,*,Auto,160,*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8" Margin="0,8,0,0">
                    <TextBlock Text="Organisasjonsnavn" Classes="form-label" />
                    <TextBox x:Name="SscOrganizationNameBox" Grid.Column="1" Grid.ColumnSpan="2" PlaceholderText="Legacy" />

                    <TextBlock Grid.Row="1" Text="Organisasjons-id" Classes="form-label" />
                    <TextBox x:Name="SscOrganizationIdBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" PlaceholderText="f95a2bc3-79bd-4c24-98b6-4e17f99bbfaf" />

                    <TextBlock Grid.Row="2" Text="bib-map.csv" Classes="form-label" />
                    <TextBox x:Name="SscBibMapPathBox" Grid.Row="2" Grid.Column="1" PlaceholderText="./siusrank-import/bib-map.csv" />
                    <Button x:Name="BrowseSscBibMapButton" Grid.Row="2" Grid.Column="2" Content="Velg fil" />

                    <TextBlock Grid.Column="3" Text="Output-mappe" Classes="form-label" />
                    <TextBox x:Name="SscOutputDirectoryBox" Grid.Column="4" PlaceholderText="./ssc-setup" />
                    <Button x:Name="BrowseSscOutputButton" Grid.Column="5" Content="Velg mappe" />

                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Users CSV" Classes="form-label" />
                    <TextBox x:Name="SscUsersCsvPathBox" Grid.Row="1" Grid.Column="4" PlaceholderText="./ssc-setup/ssc-users.csv" />
                    <Button x:Name="BrowseSscUsersCsvButton" Grid.Row="1" Grid.Column="5" Content="Velg fil" />

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Manuelt startlag" Classes="form-label" />
                    <TextBox x:Name="SscStartlagBox" Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="2" PlaceholderText="2026-07-06T09:00:00" />
                  </Grid>
                </Expander>
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="section-card">
              <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                <TextBlock Text="Arbeidsflyt" Classes="section-title" />
                <StackPanel Grid.Row="1" Spacing="6">
                  <StackPanel x:Name="SscStatusRowsPanel" Spacing="4" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="RunSscUsersButton" Content="Lag SSC-brukere" />
                    <Button x:Name="RunSscValidateButton" Content="Kontroller oppsett" />
                    <Button x:Name="RunSscLanesButton" Content="Lag banefiler" />
                  </StackPanel>
                  <TextBlock x:Name="SscUsersResultText" Classes="helper" />
                  <TextBlock x:Name="SscValidationResultText" Classes="helper" />
                  <TextBlock x:Name="SscLanesResultText" Classes="helper" />
                </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Row="2" Classes="section-card">
              <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="6">
                <TextBlock Text="Forhåndsvisning av baner" Classes="section-title" />
                <TextBlock x:Name="SscLanePreviewSummaryText" Grid.Row="1" Classes="helper" />
                <Border Grid.Row="2" Background="#f6f8fa" BorderBrush="#d0d7de" BorderThickness="1" CornerRadius="6" Padding="8,5">
                  <Grid ColumnDefinitions="70,2*,100,1.4*" ColumnSpacing="8">
                    <TextBlock Text="Bane" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="Skytter" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2" Text="UserId" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="3" Text="Øvelse" Classes="muted" FontWeight="SemiBold" />
                  </Grid>
                </Border>
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                  <StackPanel x:Name="SscLanePreviewRowsPanel" Spacing="2" />
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Diagnostics">
          <Grid RowDefinitions="Auto,*,*" Margin="0,10,0,0" RowSpacing="8">
            <Border Classes="section-card">
              <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <StackPanel>
                  <TextBlock Text="Diagnostikk" Classes="section-title" />
                  <TextBlock Text="Tabellene leser bare fra storage.db3. Loggen får kun korte sammendrag." Classes="helper" />
                </StackPanel>
                <Button x:Name="ShowStevnerButton" Grid.Column="1" Content="Vis siste stevner" VerticalAlignment="Center" />
                <Button x:Name="ShowSelectedOvelserButton" Grid.Column="2" Content="Vis valgte øvelser" VerticalAlignment="Center" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="section-card">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="6">
                <TextBlock Text="Siste stevner" Classes="section-title" />
                <Border Grid.Row="1" Background="#f6f8fa" BorderBrush="#d0d7de" BorderThickness="1" CornerRadius="6" Padding="8,5">
                  <Grid ColumnDefinitions="92,72,2*,100,100,100" ColumnSpacing="8">
                    <TextBlock Text="Dato" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="Stevne.Id" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2" Text="Navn" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="3" Text="Type" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="4" Text="Antall øvelser" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="5" Text="Startere totalt" Classes="muted" FontWeight="SemiBold" />
                  </Grid>
                </Border>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                  <StackPanel x:Name="RecentStevnerRowsPanel" Spacing="2" />
                </ScrollViewer>
              </Grid>
            </Border>

            <Border Grid.Row="2" Classes="section-card">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="6">
                <TextBlock Text="Øvelser for valgte Stevne.Id" Classes="section-title" />
                <Border Grid.Row="1" Background="#f6f8fa" BorderBrush="#d0d7de" BorderThickness="1" CornerRadius="6" Padding="8,5">
                  <Grid ColumnDefinitions="92,72,1.8*,90,1.4*,90,80" ColumnSpacing="8">
                    <TextBlock Text="Dato" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="Stevne.Id" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2" Text="Stevne" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="3" Text="OvelseDef.Id" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="4" Text="Øvelse" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="5" Text="Kortnavn" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="6" Text="Startere" Classes="muted" FontWeight="SemiBold" />
                  </Grid>
                </Border>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                  <StackPanel x:Name="SelectedOvelserRowsPanel" Spacing="2" />
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>
        </TabItem>
      </TabControl>

      <Border HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Background="#f6f8fa"
              BorderBrush="#d0d7de"
              BorderThickness="1"
              CornerRadius="6"
              Padding="6,3"
              Margin="0,0,4,0">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock x:Name="LatestLogText"
                     Width="320"
                     Classes="helper"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
          <Button x:Name="OpenLogButton"
                  Content="Logg"
                  MinWidth="68" />
        </StackPanel>
      </Border>
    </Grid>
  </DockPanel>
</Window>
