<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1180"
        d:DesignHeight="820"
        x:Class="InrxToSiusRank.Desktop.MainWindow"
        Title="InrxToSiusRank"
        MinWidth="980"
        MinHeight="720"
        Width="1180"
        Height="820">
  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_Fil">
        <MenuItem x:Name="CreateEventMenuItem" Header="_Opprett event.json" />
        <MenuItem x:Name="OpenEventMenuItem" Header="_Åpne event.json" />
        <MenuItem x:Name="SaveEventMenuItem" Header="_Lagre event.json" />
      </MenuItem>
    </Menu>

    <Border DockPanel.Dock="Top"
            Background="#f6f8fa"
            BorderBrush="#d0d7de"
            BorderThickness="0,0,0,1"
            Padding="16,12">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
        <TextBlock Text="InrxToSiusRank"
                   FontSize="20"
                   FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Text="Lokal testklient for SIUS Rank, inrX og SSC"
                   Classes="muted"
                   Margin="0,4,0,0" />
        <Border x:Name="StatusBadge"
                Grid.Column="1"
                Grid.RowSpan="2"
                Classes="status-badge">
          <TextBlock x:Name="StatusText"
                     FontWeight="SemiBold"
                     Text="Klar" />
        </Border>
      </Grid>
    </Border>

    <Grid RowDefinitions="*,230" Margin="16" RowSpacing="12">
      <TabControl Grid.Row="0">
        <TabItem Header="Event">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,12,8,0">
              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="event.json" Classes="section-title" />
                  <Grid ColumnDefinitions="150,*,Auto,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                    <TextBlock Text="Fil" Classes="form-label" />
                    <TextBox x:Name="EventFilePathBox"
                             Grid.Column="1"
                             IsReadOnly="True"
                             PlaceholderText="Ingen event-fil lastet" />
                    <Button x:Name="CreateEventButton"
                            Grid.Column="2"
                            Classes="primary"
                            Content="Opprett" />
                    <Button x:Name="OpenEventButton"
                            Grid.Column="3"
                            Content="Åpne" />
                    <Button x:Name="SaveEventButton"
                            Grid.Column="4"
                            Content="Lagre" />
                    <TextBlock x:Name="EventActionHelpText"
                               Grid.Row="1"
                               Grid.Column="1"
                               Grid.ColumnSpan="4"
                               Classes="warning-helper" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="storage.db3 og databasekontroll" Classes="section-title" />
                  <Grid ColumnDefinitions="150,*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                    <TextBlock Text="storage.db3" Classes="form-label" />
                    <TextBox x:Name="DatabasePathBox"
                             Grid.Column="1"
                             PlaceholderText="Sti til storage.db3" />
                    <Button x:Name="BrowseDatabaseButton"
                            Grid.Column="2"
                            Content="Velg fil" />
                    <Button x:Name="LoadDatabaseButton"
                            Grid.Column="3"
                            Content="Kontroller" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Grid.ColumnSpan="3"
                               Text="Velg databasen før du søker etter stevner eller lager filer."
                               Classes="helper" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="Stevnesøk og valgte Stevne.Id" Classes="section-title" />
                  <Grid ColumnDefinitions="150,*,Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                    <TextBlock Text="Stevnesøk" Classes="form-label" />
                    <TextBox x:Name="StevneSearchBox"
                             Grid.Column="1"
                             PlaceholderText="Navn eller dato, tom = siste 100" />
                    <Button x:Name="SearchStevnerButton"
                            Grid.Column="2"
                            Content="Søk" />
                    <Button x:Name="RefreshEventClassesButton"
                            Grid.Column="3"
                            Content="Oppdater klasser" />
                    <Button x:Name="SelectAllStevnerButton"
                            Grid.Column="4"
                            Content="Velg alle" />
                    <Button x:Name="ClearStevnerButton"
                            Grid.Column="5"
                            Content="Fjern valg" />

                    <TextBlock x:Name="StevneResultCountText"
                               Grid.Row="1"
                               Grid.Column="1"
                               Grid.ColumnSpan="5"
                               Classes="helper"
                               Text="Ingen søk kjørt." />

                    <Border Grid.Row="2"
                            Grid.Column="1"
                            Grid.ColumnSpan="5"
                            Background="#f6f8fa"
                            BorderBrush="#d0d7de"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6">
                      <Grid ColumnDefinitions="32,110,70,2*,110,2*" ColumnSpacing="8">
                        <TextBlock Grid.Column="1" Text="Dato" Classes="muted" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="Id" Classes="muted" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="Navn" Classes="muted" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="4" Text="Type" Classes="muted" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="5" Text="Øvelser" Classes="muted" FontWeight="SemiBold" />
                      </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="3"
                                  Grid.Column="1"
                                  Grid.ColumnSpan="5"
                                  MaxHeight="190"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                      <StackPanel x:Name="StevneListPanel" Spacing="4" />
                    </ScrollViewer>
                  </Grid>

                  <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6" Margin="0,10,0,0">
                    <TextBlock Text="Valgte ids" Classes="form-label" />
                    <TextBox x:Name="StevneIdsBox"
                             Grid.Column="1"
                             PlaceholderText="413-417 eller 413,414" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="Brukes av eksport, writeback og SSC."
                               Classes="helper" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="Stevnetype og encoding" Classes="section-title" />
                  <Grid ColumnDefinitions="150,*,150,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                    <TextBlock Text="Stevnetype" Classes="form-label" VerticalAlignment="Top" />
                    <ScrollViewer Grid.Column="1" MaxHeight="140" VerticalScrollBarVisibility="Auto">
                      <StackPanel x:Name="EventTypesPanel" Spacing="6" />
                    </ScrollViewer>

                    <TextBlock Grid.Column="2" Text="Encoding" Classes="form-label" />
                    <ComboBox x:Name="EncodingBox"
                              Grid.Column="3"
                              Width="180"
                              HorizontalAlignment="Left"
                              SelectedIndex="0">
                      <ComboBoxItem Content="utf8-bom" />
                      <ComboBoxItem Content="windows-1252" />
                    </ComboBox>
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Grid.ColumnSpan="3"
                               Text="Stevnetype lagres i event.json. Encoding brukes for CSV- og SSC-filer."
                               Classes="helper" />
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="CSV export">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,12,8,0">
              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="SIUS Rank og template-stier" Classes="section-title" />
                  <Grid ColumnDefinitions="170,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                    <TextBlock Text="SIUS Rank-mappe" Classes="form-label" />
                    <TextBox x:Name="SiusRankFolderBox"
                             Grid.Column="1"
                             PlaceholderText="C:\SIUS\SiusRank" />
                    <Button x:Name="BrowseSiusRankFolderButton"
                            Grid.Column="2"
                            Content="Velg mappe" />

                    <TextBlock Grid.Row="1" Text="Output-mappe" Classes="form-label" />
                    <TextBox x:Name="OutputDirectoryBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             PlaceholderText="siusrank-import mappe" />
                    <Button x:Name="BrowseOutputButton"
                            Grid.Row="1"
                            Grid.Column="2"
                            Content="Velg mappe" />

                    <TextBlock Grid.Row="2" Text="ShooterGroupsTemplate.xml" Classes="form-label" />
                    <TextBox x:Name="ShooterGroupsTemplateBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             PlaceholderText="Valgfri ShooterGroupsTemplate.xml" />
                    <Button x:Name="BrowseShooterGroupsButton"
                            Grid.Row="2"
                            Grid.Column="2"
                            Content="Velg fil" />

                    <TextBlock Grid.Row="3" Text="SIUS templates" Classes="form-label" />
                    <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
                      <Button x:Name="CopyTemplatesButton" Content="Kopier templates til SIUS Rank" />
                      <TextBlock VerticalAlignment="Center"
                                 Classes="helper"
                                 Text="C:\SIUS\SiusRank\Resources\Templates" />
                    </StackPanel>

                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Text="Template-kopiering påvirker bare lokale SIUS Rank template-filer."
                               Classes="helper" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="Øvelse og silhuett" Classes="section-title" />
                  <Grid ColumnDefinitions="170,*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                    <TextBlock Text="Øvelse" Classes="form-label" />
                    <ComboBox x:Name="OvelseSelectBox"
                              Grid.Column="1"
                              MinWidth="280" />
                    <Button x:Name="RefreshOvelserButton"
                            Grid.Column="2"
                            Content="Oppdater øvelser" />
                    <TextBox x:Name="OvelseFilterBox" IsVisible="False" />

                    <TextBlock Grid.Row="1" Text="Silhuett" Classes="form-label" />
                    <ComboBox x:Name="SilhouetteShootersPerStandBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Width="200"
                              HorizontalAlignment="Left"
                              SelectedIndex="1">
                      <ComboBoxItem Content="1 skytter per stativ" />
                      <ComboBoxItem Content="2 skyttere per stativ" />
                    </ComboBox>

                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Text="Øvelseslisten hentes fra valgte Stevne.Id i storage.db3."
                               Classes="helper" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="CSV-handlinger" Classes="section-title" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="CreateBibMapButton"
                            Content="Opprett/oppdater bib-map.csv" />
                    <Button x:Name="RunExportButton"
                            Classes="primary"
                            Content="Lag CSV-filer" />
                  </StackPanel>
                  <TextBlock x:Name="CsvActionHelpText"
                             Margin="0,8,0,0"
                             Classes="warning-helper" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="SIUS Rank writeback">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,12,8,0">
              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="Eksportmappe, bib-map.csv og eventfilter" Classes="section-title" />
                  <Grid ColumnDefinitions="170,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                    <TextBlock Text="Eksportmappe" Classes="form-label" />
                    <TextBox x:Name="ExportsDirectoryBox"
                             Grid.Column="1"
                             PlaceholderText="SIUS Rank Exports mappe" />
                    <Button x:Name="BrowseExportsButton"
                            Grid.Column="2"
                            Content="Velg mappe" />

                    <TextBlock Grid.Row="1" Text="bib-map.csv" Classes="form-label" />
                    <TextBox x:Name="BibMapPathBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             PlaceholderText="Valgfri, auto-detekteres hvis tom" />
                    <Button x:Name="BrowseBibMapButton"
                            Grid.Row="1"
                            Grid.Column="2"
                            Content="Velg fil" />

                    <TextBlock Grid.Row="2" Text="Eventfilter" Classes="form-label" />
                    <TextBox x:Name="EventFilterBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Grid.ColumnSpan="2"
                             PlaceholderText="Valgfritt: HurtigFin_M,HurtigGrov_Apen" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Text="Writeback leser Rank List Main ODF XML fra SIUS Rank Exports."
                               Classes="helper" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="Tørrkjør og skriv tilbake" Classes="section-title" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="RunWritebackPreviewButton"
                            Content="Tørrkjør writeback" />
                    <Button x:Name="RunWritebackApplyButton"
                            Classes="danger"
                            Content="Skriv til inrX" />
                  </StackPanel>
                  <TextBlock x:Name="WritebackActionHelpText"
                             Margin="0,8,0,0"
                             Classes="warning-helper" />
                </StackPanel>
              </Border>

              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="Validering og writeback per klasse" Classes="section-title" />
                  <Grid ColumnDefinitions="120,300,150,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,6">
                    <TextBlock Text="Klasse" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="Eksportmappe" Classes="muted" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2" Text="Status" Classes="muted" FontWeight="SemiBold" />
                  </Grid>
                  <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel x:Name="WritebackClassRowsPanel" Spacing="6" />
                  </ScrollViewer>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="SSC">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,12,8,0">
              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="Organisasjon" Classes="section-title" />
                  <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                    <TextBlock Text="Organisasjonsnavn" Classes="form-label" />
                    <TextBox x:Name="SscOrganizationNameBox"
                             Grid.Column="1"
                             PlaceholderText="Legacy" />

                    <TextBlock Grid.Row="1" Text="Organisasjons-id" Classes="form-label" />
                    <TextBox x:Name="SscOrganizationIdBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             PlaceholderText="f95a2bc3-79bd-4c24-98b6-4e17f99bbfaf" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="Input- og outputfiler" Classes="section-title" />
                  <Grid ColumnDefinitions="170,*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                    <TextBlock Text="bib-map.csv" Classes="form-label" />
                    <TextBox x:Name="SscBibMapPathBox"
                             Grid.Column="1"
                             PlaceholderText="siusrank-import/bib-map.csv" />
                    <Button x:Name="BrowseSscBibMapButton"
                            Grid.Column="2"
                            Content="Velg fil" />

                    <TextBlock Grid.Row="1" Text="Output-mappe" Classes="form-label" />
                    <TextBox x:Name="SscOutputDirectoryBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             PlaceholderText="ssc setup output mappe" />
                    <Button x:Name="BrowseSscOutputButton"
                            Grid.Row="1"
                            Grid.Column="2"
                            Content="Velg mappe" />

                    <TextBlock Grid.Row="2" Text="Users CSV" Classes="form-label" />
                    <TextBox x:Name="SscUsersCsvPathBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             PlaceholderText="ssc-users.csv for validering" />
                    <Button x:Name="BrowseSscUsersCsvButton"
                            Grid.Row="2"
                            Grid.Column="2"
                            Content="Velg fil" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="Baner og startlag" Classes="section-title" />
                  <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                    <TextBlock Text="Startlag" Classes="form-label" />
                    <TextBox x:Name="SscStartlagBox"
                             Grid.Column="1"
                             PlaceholderText="2026-07-06T09:00:00" />

                    <TextBlock Grid.Row="1" Text="Antall baner" Classes="form-label" />
                    <ComboBox x:Name="SscLaneCountBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Width="90"
                              HorizontalAlignment="Left"
                              SelectedIndex="2">
                      <ComboBoxItem Content="10" />
                      <ComboBoxItem Content="25" />
                      <ComboBoxItem Content="40" />
                    </ComboBox>

                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="Eksport av SSC baner/reset krever nøyaktig én Stevne.Id."
                               Classes="helper" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="SSC-handlinger" Classes="section-title" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="RunSscUsersButton"
                            Classes="primary"
                            Content="Eksporter SSC-brukere" />
                    <Button x:Name="RunSscValidateButton"
                            Content="Valider SSC" />
                    <Button x:Name="RunSscLanesButton"
                            Content="Eksporter SSC baner/reset" />
                  </StackPanel>
                  <TextBlock x:Name="SscActionHelpText"
                             Margin="0,8,0,0"
                             Classes="warning-helper" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Diagnostics">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,12,8,0">
              <Border Classes="section-card">
                <StackPanel>
                  <TextBlock Text="Diagnostikk" Classes="section-title" />
                  <TextBlock Text="Disse knappene leser bare fra storage.db3 og skriver sammendrag til loggen."
                             Classes="helper"
                             Margin="0,0,0,10" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="ShowStevnerButton" Content="Vis siste stevner" />
                    <Button x:Name="ShowSelectedOvelserButton" Content="Vis valgte øvelser" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
      </TabControl>

      <Grid Grid.Row="1" RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,6" ColumnSpacing="8">
          <TextBlock Text="Logg" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button x:Name="CopyLogButton" Grid.Column="1" Content="Kopier logg" />
          <Button x:Name="SaveLogButton" Grid.Column="2" Content="Lagre logg..." />
          <Button x:Name="ClearLogButton" Grid.Column="3" Content="Tøm" />
        </Grid>
        <TextBox x:Name="LogBox"
                 Grid.Row="1"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas, Menlo, Cascadia Mono, monospace"
                 FontSize="12" />
      </Grid>
    </Grid>
  </DockPanel>
</Window>
